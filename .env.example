# Cot-ExplorerV2 API Keys
# All keys are OPTIONAL — the system runs fully on public data without them.
# Add keys here for premium features (higher rate limits, more data sources).

# Price Data (premium — higher rate limits, more symbols)
TWELVEDATA_API_KEY=
FINNHUB_API_KEY=

# Macro Data (premium — higher rate limit, default public key works)
FRED_API_KEY=

# Signal Distribution (optional — enable Telegram/Discord alerts)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
DISCORD_WEBHOOK=

# API Authentication (for the REST API server)
SCALP_API_KEY=

# Database (default: SQLite in data/cot-explorer.db)
# DATABASE_URL=sqlite:///data/cot-explorer.db
