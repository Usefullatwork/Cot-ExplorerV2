// =============================================================================
// VIX Regime — Bakgrunnsfarge og posisjonsstorrelse basert pa VIX-niva
// Henter VIX fra CBOE:VIX daglig
// =============================================================================
//@version=5
indicator("COT Explorer: VIX Regime", shorttitle="VIX", overlay=true)

// ── Fargepalett (mork tema) ─────────────────────────────────────────────────
var color C_GREEN  = #3fb950
var color C_RED    = #f85149
var color C_YELLOW = #d29922
var color C_BLUE   = #58a6ff
var color C_BG     = #161b22
var color C_TEXT   = #c9d1d9

// ── Inputs ──────────────────────────────────────────────────────────────────
extreme_thresh  = input.float(30.0, "Ekstrem-terskel (VIX)", step=1.0)
elevated_thresh = input.float(25.0, "Forhoyet-terskel (VIX)", step=1.0)
normal_thresh   = input.float(20.0, "Normal-terskel (VIX)",   step=1.0)
show_table      = input.bool(true,  "Vis VIX-tabell")

// ── Hent VIX daglig ────────────────────────────────────────────────────────
vix = request.security("CBOE:VIX", "D", close, lookahead=barmerge.lookahead_on)
vix_prev = request.security("CBOE:VIX", "D", close[1], lookahead=barmerge.lookahead_on)
vix_chg  = vix - vix_prev

// ── Regime-klassifisering ───────────────────────────────────────────────────
regime_label() =>
    if vix >= extreme_thresh
        "EXTREME"
    else if vix >= elevated_thresh
        "ELEVATED"
    else if vix >= normal_thresh
        "FORHOY"
    else
        "NORMAL"

pos_size_label() =>
    if vix >= extreme_thresh
        "QUARTER"
    else if vix >= normal_thresh
        "HALF"
    else
        "FULL"

pos_factor() =>
    if vix >= extreme_thresh
        0.25
    else if vix >= normal_thresh
        0.5
    else
        1.0

regime = regime_label()
pos_size = pos_size_label()

// ── Bakgrunnsfarge ──────────────────────────────────────────────────────────
bg_col = vix >= extreme_thresh  ? color.new(C_RED, 85) :
         vix >= elevated_thresh ? color.new(C_YELLOW, 88) :
         vix >= normal_thresh   ? color.new(C_YELLOW, 93) :
         na

bgcolor(bg_col, title="VIX Regime bakgrunn")

// ── Tabell (ovre venstre) ───────────────────────────────────────────────────
if show_table and barstate.islast
    var table vt = table.new(position.top_left, 2, 4, bgcolor=C_BG, border_width=1, border_color=color.new(C_TEXT, 70))

    // VIX-verdi
    vix_col = vix >= extreme_thresh ? C_RED : vix >= normal_thresh ? C_YELLOW : C_GREEN
    table.cell(vt, 0, 0, "VIX",    text_color=C_TEXT,  text_size=size.tiny, text_halign=text.align_left)
    table.cell(vt, 1, 0, str.tostring(vix, "#0.1"), text_color=vix_col, text_size=size.small)

    // Endring
    chg_col = vix_chg > 0 ? C_RED : vix_chg < 0 ? C_GREEN : C_TEXT
    table.cell(vt, 0, 1, "Endring",  text_color=C_TEXT, text_size=size.tiny, text_halign=text.align_left)
    table.cell(vt, 1, 1, str.tostring(vix_chg, "+#0.1"), text_color=chg_col, text_size=size.tiny)

    // Regime
    regime_col = regime == "EXTREME" ? C_RED : regime == "NORMAL" ? C_GREEN : C_YELLOW
    table.cell(vt, 0, 2, "Regime",   text_color=C_TEXT, text_size=size.tiny, text_halign=text.align_left)
    table.cell(vt, 1, 2, regime,     text_color=regime_col, text_size=size.small)

    // Posisjonsstorrelse
    table.cell(vt, 0, 3, "Storrelse", text_color=C_TEXT, text_size=size.tiny, text_halign=text.align_left)
    ps_col = pos_size == "FULL" ? C_GREEN : pos_size == "HALF" ? C_YELLOW : C_RED
    table.cell(vt, 1, 3, pos_size,    text_color=ps_col, text_size=size.small)
