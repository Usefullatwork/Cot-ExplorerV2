//@version=5
// =============================================================================
// Macro Dashboard [CotExplorer]
//
// Table-based dashboard showing macro regime indicators:
//   - VIX level and regime classification
//   - Dollar Index (DXY) trend
//   - Yield curve approximation (10Y - 2Y spread)
//   - Fear & Greed estimation from price action
//   - Risk regime classification
//   - Position sizing recommendation
//
// Uses real-time security requests to fetch VIX, DXY, and yield data.
// =============================================================================
indicator("Macro Dashboard [CotExplorer]", overlay=true)

// ── Settings ─────────────────────────────────────────────────────────────────
tablePos    = input.string("top_right", "Table Position", options=["top_right", "top_left", "bottom_right", "bottom_left"])
showVIX     = input.bool(true, "Show VIX")
showDXY     = input.bool(true, "Show DXY")
showYield   = input.bool(true, "Show Yield Curve")
showFG      = input.bool(true, "Show Fear & Greed Est.")
showRegime  = input.bool(true, "Show Risk Regime")
showSizing  = input.bool(true, "Show Position Sizing")
vixSymbol   = input.symbol("CBOE:VIX", "VIX Symbol")
dxySymbol   = input.symbol("TVC:DXY", "DXY Symbol")
us10ySymbol = input.symbol("TVC:US10Y", "US 10Y Yield")
us02ySymbol = input.symbol("TVC:US02Y", "US 2Y Yield")

// VIX thresholds
vixLow   = input.float(18.0, "VIX Low (Normal)")
vixMid   = input.float(25.0, "VIX Mid (Elevated)")
vixHigh  = input.float(30.0, "VIX High (Extreme)")

// DXY lookback
dxyLookback = input.int(20, "DXY Trend Lookback (bars)")

// ── Data Fetching ────────────────────────────────────────────────────────────
vixClose  = request.security(vixSymbol, "D", close)
vixPrev5  = request.security(vixSymbol, "D", close[5])
dxyClose  = request.security(dxySymbol, "D", close)
dxyPrev   = request.security(dxySymbol, "D", close[dxyLookback])
us10y     = request.security(us10ySymbol, "D", close)
us02y     = request.security(us02ySymbol, "D", close)

// ── Calculations ─────────────────────────────────────────────────────────────

// VIX regime
vixRegime = vixClose > vixHigh ? "EXTREME FEAR" :
            vixClose > vixMid ? "ELEVATED" :
            vixClose > vixLow ? "NORMAL" :
            "LOW VOL"

vixColor = vixClose > vixHigh ? color.red :
           vixClose > vixMid ? color.orange :
           vixClose > vixLow ? color.yellow :
           color.green

vixChg5d = na(vixPrev5) or vixPrev5 == 0 ? 0.0 : (vixClose / vixPrev5 - 1) * 100

// DXY trend
dxyChg = na(dxyPrev) or dxyPrev == 0 ? 0.0 : (dxyClose / dxyPrev - 1) * 100
dxyTrend = dxyChg > 0.5 ? "STRENGTHENING" :
           dxyChg < -0.5 ? "WEAKENING" :
           "FLAT"
dxyColor = dxyChg > 0.5 ? color.green :
           dxyChg < -0.5 ? color.red :
           color.gray

// Yield curve (10Y - 2Y)
yieldSpread = na(us10y) or na(us02y) ? na : us10y - us02y
yieldLabel  = na(yieldSpread) ? "N/A" :
              yieldSpread < -0.3 ? "INVERTED" :
              yieldSpread < 0 ? "FLAT/NEG" :
              yieldSpread < 0.5 ? "FLAT/POS" :
              "NORMAL"
yieldColor  = na(yieldSpread) ? color.gray :
              yieldSpread < -0.3 ? color.red :
              yieldSpread < 0 ? color.orange :
              yieldSpread < 0.5 ? color.yellow :
              color.green

// Fear & Greed estimation from price action
// Uses a composite of: RSI, distance from SMA200, VIX, recent momentum
rsi14 = ta.rsi(close, 14)
sma200 = ta.sma(close, 200)
distSMA200 = na(sma200) or sma200 == 0 ? 0.0 : (close / sma200 - 1) * 100

// Score components (each 0-25, total 0-100)
fgRSI  = na(rsi14) ? 50.0 : rsi14
fgVIX  = na(vixClose) ? 50.0 : math.max(0, math.min(100, 100 - (vixClose - 10) * 2.5))
fgMom  = na(sma200) ? 50.0 : math.max(0, math.min(100, 50 + distSMA200 * 5))
chg20  = bar_index >= 20 and close[20] != 0 ? (close / close[20] - 1) * 100 : 0
fgTrend = math.max(0, math.min(100, 50 + chg20 * 3))

fgScore = (fgRSI + fgVIX + fgMom + fgTrend) / 4.0
fgLabel = fgScore > 75 ? "EXTREME GREED" :
          fgScore > 60 ? "GREED" :
          fgScore > 40 ? "NEUTRAL" :
          fgScore > 25 ? "FEAR" :
          "EXTREME FEAR"
fgColor = fgScore > 75 ? color.lime :
          fgScore > 60 ? color.green :
          fgScore > 40 ? color.gray :
          fgScore > 25 ? color.orange :
          color.red

// Overall risk regime
regime = vixClose > vixHigh ? "RISK OFF" :
         vixClose > vixMid and dxyChg > 0.5 ? "RISK OFF" :
         vixClose < vixLow and dxyChg < -0.5 ? "RISK ON" :
         vixClose < vixLow ? "RISK ON" :
         "NEUTRAL"
regimeColor = regime == "RISK ON" ? color.green :
              regime == "RISK OFF" ? color.red :
              color.yellow

// Dollar Smile classification
smile = vixClose > vixHigh ? "LEFT (Safe Haven)" :
        vixClose < vixLow and dxyChg < -0.5 ? "MIDDLE (Goldilocks)" :
        "RIGHT (Growth)"
smileColor = smile == "LEFT (Safe Haven)" ? color.red :
             smile == "MIDDLE (Goldilocks)" ? color.green :
             color.blue

// Position sizing
posSize = vixClose > vixHigh ? "QUARTER" :
          vixClose > vixMid ? "HALF" :
          "FULL"
posSizeColor = posSize == "QUARTER" ? color.red :
               posSize == "HALF" ? color.orange :
               color.green

// ── Table Display ────────────────────────────────────────────────────────────
tblPos = tablePos == "top_right" ? position.top_right :
         tablePos == "top_left" ? position.top_left :
         tablePos == "bottom_right" ? position.bottom_right :
         position.bottom_left

numRows = 1 + (showVIX ? 1 : 0) + (showDXY ? 1 : 0) + (showYield ? 1 : 0) + (showFG ? 1 : 0) + (showRegime ? 2 : 0) + (showSizing ? 1 : 0)

var table dashboard = table.new(tblPos, 3, 10, bgcolor=color.new(color.black, 80), border_width=1, border_color=color.new(color.gray, 60))

if barstate.islast
    row = 0

    // Title
    table.cell(dashboard, 0, row, "MACRO", text_color=color.white, text_size=size.small, text_halign=text.align_left)
    table.cell(dashboard, 1, row, "VALUE", text_color=color.white, text_size=size.small)
    table.cell(dashboard, 2, row, "STATUS", text_color=color.white, text_size=size.small)
    row += 1

    if showVIX
        table.cell(dashboard, 0, row, "VIX", text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
        table.cell(dashboard, 1, row, str.tostring(vixClose, "#.#") + " (" + str.tostring(vixChg5d, "+#.#;-#.#") + "% 5d)", text_color=vixColor, text_size=size.tiny)
        table.cell(dashboard, 2, row, vixRegime, text_color=vixColor, text_size=size.tiny)
        row += 1

    if showDXY
        table.cell(dashboard, 0, row, "DXY", text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
        table.cell(dashboard, 1, row, str.tostring(dxyClose, "#.##") + " (" + str.tostring(dxyChg, "+#.#;-#.#") + "% " + str.tostring(dxyLookback) + "d)", text_color=dxyColor, text_size=size.tiny)
        table.cell(dashboard, 2, row, dxyTrend, text_color=dxyColor, text_size=size.tiny)
        row += 1

    if showYield
        yieldText = na(yieldSpread) ? "N/A" : str.tostring(yieldSpread, "+#.##;-#.##") + "%"
        table.cell(dashboard, 0, row, "10Y-2Y", text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
        table.cell(dashboard, 1, row, yieldText, text_color=yieldColor, text_size=size.tiny)
        table.cell(dashboard, 2, row, yieldLabel, text_color=yieldColor, text_size=size.tiny)
        row += 1

    if showFG
        table.cell(dashboard, 0, row, "F&G Est.", text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
        table.cell(dashboard, 1, row, str.tostring(fgScore, "#.#"), text_color=fgColor, text_size=size.tiny)
        table.cell(dashboard, 2, row, fgLabel, text_color=fgColor, text_size=size.tiny)
        row += 1

    if showRegime
        table.cell(dashboard, 0, row, "REGIME", text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
        table.cell(dashboard, 1, row, regime, text_color=regimeColor, text_size=size.tiny)
        table.cell(dashboard, 2, row, smile, text_color=smileColor, text_size=size.tiny)
        row += 1

    if showSizing
        table.cell(dashboard, 0, row, "POS SIZE", text_color=color.white, text_size=size.tiny, text_halign=text.align_left)
        table.cell(dashboard, 1, row, posSize, text_color=posSizeColor, text_size=size.tiny)
        table.cell(dashboard, 2, row, "VIX-adjusted", text_color=color.gray, text_size=size.tiny)
        row += 1

// ── Alerts ───────────────────────────────────────────────────────────────────
alertcondition(vixClose > vixHigh and vixClose[1] <= vixHigh, "VIX Extreme", "VIX crossed above extreme threshold")
alertcondition(ta.crossunder(vixClose, vixLow), "VIX Low", "VIX dropped below low volatility threshold")
alertcondition(na(yieldSpread) ? false : yieldSpread < -0.3 and yieldSpread[1] >= -0.3, "Yield Curve Inversion", "Yield curve 10Y-2Y inverted beyond -0.3%")
