//@version=5
// =============================================================================
// SMC Zones — Smart Money Concepts for TradingView
// Ported from Cot-ExplorerV2 smc.py (FluidTrades SMC Lite)
//
// Features:
//   - Pivot High/Low detection
//   - Supply/Demand zone boxes (red/green)
//   - BOS (Break of Structure) / CHoCH lines
//   - Swing labels: HH, HL, LH, LL
//   - Zone invalidation when price breaks through
// =============================================================================
indicator("SMC Zones [CotExplorer]", overlay=true, max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// ── Settings ─────────────────────────────────────────────────────────────────
pivotLen     = input.int(10, "Pivot Length", minval=2, maxval=50, tooltip="Bars on each side to confirm a pivot. Higher = fewer but stronger pivots.")
boxWidth     = input.float(2.5, "Zone ATR Buffer (x10)", minval=0.5, maxval=10.0, step=0.5, tooltip="Zone thickness as fraction of ATR. 2.5 means ATR * 0.25.")
atrLen       = input.int(50, "ATR Length", minval=5, maxval=200)
maxZones     = input.int(20, "Max Zones to Show", minval=5, maxval=50)
showZones    = input.bool(true, "Show Supply/Demand Zones")
showBOS      = input.bool(true, "Show BOS Lines")
showSwings   = input.bool(true, "Show Swing Labels (HH/HL/LH/LL)")
showPOI      = input.bool(true, "Show POI (Point of Interest) Lines")
demandColor  = input.color(color.new(color.green, 80), "Demand Zone Color")
supplyColor  = input.color(color.new(color.red, 80), "Supply Zone Color")
bosUpColor   = input.color(color.new(color.teal, 30), "BOS Up Color")
bosDownColor = input.color(color.new(color.maroon, 30), "BOS Down Color")

// ── ATR Calculation ──────────────────────────────────────────────────────────
atr = ta.atr(atrLen)

// ── Pivot Detection ──────────────────────────────────────────────────────────
// ta.pivothigh/low returns the value at the pivot point, offset by pivotLen bars
pivotHigh = ta.pivothigh(high, pivotLen, pivotLen)
pivotLow  = ta.pivotlow(low, pivotLen, pivotLen)

// ── Swing Classification ─────────────────────────────────────────────────────
// Track last two swing highs and lows to classify HH/LH/HL/LL
var float lastSwingHigh  = na
var float prevSwingHigh  = na
var float lastSwingLow   = na
var float prevSwingLow   = na
var string highLabel      = ""
var string lowLabel       = ""

if not na(pivotHigh)
    prevSwingHigh := lastSwingHigh
    lastSwingHigh := pivotHigh
    if na(prevSwingHigh)
        highLabel := "HH"
    else
        highLabel := pivotHigh >= prevSwingHigh ? "HH" : "LH"

    if showSwings
        labelColor = highLabel == "HH" ? color.green : color.orange
        label.new(
             bar_index - pivotLen, pivotHigh,
             highLabel,
             style=label.style_label_down,
             color=labelColor,
             textcolor=color.white,
             size=size.tiny
             )

if not na(pivotLow)
    prevSwingLow := lastSwingLow
    lastSwingLow := pivotLow
    if na(prevSwingLow)
        lowLabel := "HL"
    else
        lowLabel := pivotLow >= prevSwingLow ? "HL" : "LL"

    if showSwings
        labelColor = lowLabel == "HL" ? color.green : color.red
        label.new(
             bar_index - pivotLen, pivotLow,
             lowLabel,
             style=label.style_label_up,
             color=labelColor,
             textcolor=color.white,
             size=size.tiny
             )

// ── Market Structure ─────────────────────────────────────────────────────────
// Determine overall structure from latest swing labels
var string structure = "MIXED"

if highLabel == "HH" and lowLabel == "HL"
    structure := "BULLISH"
else if highLabel == "LH" and lowLabel == "LL"
    structure := "BEARISH"
else if highLabel == "HH"
    structure := "BULLISH_WEAK"
else if lowLabel == "LL"
    structure := "BEARISH_WEAK"
else
    structure := "MIXED"

// ── Supply/Demand Zone Arrays ────────────────────────────────────────────────
// Store zone data in arrays for dynamic management
var box[] supplyBoxes = array.new_box()
var box[] demandBoxes = array.new_box()
var float[] supplyTops = array.new_float()
var float[] supplyBots = array.new_float()
var float[] demandTops = array.new_float()
var float[] demandBots = array.new_float()

// ATR-based zone thickness
atrBuffer  = nz(atr) * (boxWidth / 10.0)
atrOverlap = nz(atr) * 2.0

// Helper: check if a new POI overlaps existing zones
f_overlapping(newPOI, tops, bots) =>
    result = false
    for i = 0 to array.size(tops) - 1
        existPOI = (array.get(tops, i) + array.get(bots, i)) / 2.0
        if math.abs(newPOI - existPOI) <= atrOverlap
            result := true
            break
    result

// ── Create New Zones ─────────────────────────────────────────────────────────
if showZones
    // Supply zone at pivot high
    if not na(pivotHigh)
        zoneTop = pivotHigh
        zoneBot = pivotHigh - atrBuffer
        zonePOI = (zoneTop + zoneBot) / 2.0

        if not f_overlapping(zonePOI, supplyTops, supplyBots)
            // Limit total zones
            if array.size(supplyBoxes) >= maxZones
                box.delete(array.shift(supplyBoxes))
                array.shift(supplyTops)
                array.shift(supplyBots)

            newBox = box.new(
                 bar_index - pivotLen, zoneTop,
                 bar_index + 200, zoneBot,
                 border_color=color.new(color.red, 60),
                 bgcolor=supplyColor,
                 border_width=1
                 )
            array.push(supplyBoxes, newBox)
            array.push(supplyTops, zoneTop)
            array.push(supplyBots, zoneBot)

            // POI line
            if showPOI
                line.new(
                     bar_index - pivotLen, zonePOI,
                     bar_index + 200, zonePOI,
                     color=color.new(color.red, 70),
                     style=line.style_dotted,
                     width=1
                     )

    // Demand zone at pivot low
    if not na(pivotLow)
        zoneBot = pivotLow
        zoneTop = pivotLow + atrBuffer
        zonePOI = (zoneTop + zoneBot) / 2.0

        if not f_overlapping(zonePOI, demandTops, demandBots)
            if array.size(demandBoxes) >= maxZones
                box.delete(array.shift(demandBoxes))
                array.shift(demandTops)
                array.shift(demandBots)

            newBox = box.new(
                 bar_index - pivotLen, zoneTop,
                 bar_index + 200, zoneBot,
                 border_color=color.new(color.green, 60),
                 bgcolor=demandColor,
                 border_width=1
                 )
            array.push(demandBoxes, newBox)
            array.push(demandTops, zoneTop)
            array.push(demandBots, zoneBot)

            if showPOI
                line.new(
                     bar_index - pivotLen, zonePOI,
                     bar_index + 200, zonePOI,
                     color=color.new(color.green, 70),
                     style=line.style_dotted,
                     width=1
                     )

// ── Zone Invalidation (BOS Detection) ────────────────────────────────────────
// When close breaks through a zone, mark it as broken (delete the box)
// and draw a BOS line

if showZones
    // Check supply zones: close above top = broken (BOS up)
    for i = array.size(supplyBoxes) - 1 to 0
        if i < array.size(supplyTops)
            zTop = array.get(supplyTops, i)
            if close >= zTop
                if showBOS
                    zBot = array.get(supplyBots, i)
                    zPOI = (zTop + zBot) / 2.0
                    line.new(
                         bar_index - 1, zPOI,
                         bar_index, zPOI,
                         color=bosUpColor,
                         style=line.style_solid,
                         width=2,
                         extend=extend.right
                         )
                    label.new(
                         bar_index, zPOI,
                         "BOS",
                         style=label.style_label_left,
                         color=bosUpColor,
                         textcolor=color.white,
                         size=size.tiny
                         )

                box.delete(array.get(supplyBoxes, i))
                array.remove(supplyBoxes, i)
                array.remove(supplyTops, i)
                array.remove(supplyBots, i)

    // Check demand zones: close below bottom = broken (BOS down)
    for i = array.size(demandBoxes) - 1 to 0
        if i < array.size(demandBots)
            zBot = array.get(demandBots, i)
            if close <= zBot
                if showBOS
                    zTop = array.get(demandTops, i)
                    zPOI = (zTop + zBot) / 2.0
                    line.new(
                         bar_index - 1, zPOI,
                         bar_index, zPOI,
                         color=bosDownColor,
                         style=line.style_solid,
                         width=2,
                         extend=extend.right
                         )
                    label.new(
                         bar_index, zPOI,
                         "BOS",
                         style=label.style_label_left,
                         color=bosDownColor,
                         textcolor=color.white,
                         size=size.tiny
                         )

                box.delete(array.get(demandBoxes, i))
                array.remove(demandBoxes, i)
                array.remove(demandTops, i)
                array.remove(demandBots, i)

// ── Structure Info Table ─────────────────────────────────────────────────────
var table infoTable = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 85), border_width=1)

if barstate.islast
    structColor = structure == "BULLISH" ? color.green : structure == "BEARISH" ? color.red : color.gray

    table.cell(infoTable, 0, 0, "Structure", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, structure, text_color=structColor, text_size=size.small)

    table.cell(infoTable, 0, 1, "Last HH/LH", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 1, highLabel + " @ " + str.tostring(lastSwingHigh, format.mintick), text_color=highLabel == "HH" ? color.green : color.orange, text_size=size.small)

    table.cell(infoTable, 0, 2, "Last HL/LL", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 2, lowLabel + " @ " + str.tostring(lastSwingLow, format.mintick), text_color=lowLabel == "HL" ? color.green : color.red, text_size=size.small)

    table.cell(infoTable, 0, 3, "ATR(" + str.tostring(atrLen) + ")", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 3, str.tostring(atr, format.mintick), text_color=color.gray, text_size=size.small)
