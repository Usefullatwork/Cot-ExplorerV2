# Cot-ExplorerV2 Pipeline Schedule
# Install with: sudo crontab -u cotexplorer scripts/crontab.example
#
# 4x daily runs, weekdays only (Mon-Fri)
# Times in UTC (adjust for your timezone)
#   06:45 UTC = 07:45 CET  — Pre-London session
#   11:30 UTC = 12:30 CET  — Midday update (NY open)
#   13:15 UTC = 14:15 CET  — Afternoon update
#   16:15 UTC = 17:15 CET  — End-of-day update
#
# Each run fetches fresh COT/price data, scores instruments,
# and pushes signals to Telegram/Discord.

SHELL=/bin/bash
PATH=/opt/cot-explorer/venv/bin:/usr/local/bin:/usr/bin:/bin

# -- Pipeline runs --
45 6  * * 1-5  cd /opt/cot-explorer && /opt/cot-explorer/venv/bin/python -m src.pipeline.runner >> /opt/cot-explorer/logs/pipeline.log 2>&1
30 11 * * 1-5  cd /opt/cot-explorer && /opt/cot-explorer/venv/bin/python -m src.pipeline.runner >> /opt/cot-explorer/logs/pipeline.log 2>&1
15 13 * * 1-5  cd /opt/cot-explorer && /opt/cot-explorer/venv/bin/python -m src.pipeline.runner >> /opt/cot-explorer/logs/pipeline.log 2>&1
15 16 * * 1-5  cd /opt/cot-explorer && /opt/cot-explorer/venv/bin/python -m src.pipeline.runner >> /opt/cot-explorer/logs/pipeline.log 2>&1

# -- Weekly backtest (Sunday 03:00 UTC) --
0  3  * * 0    cd /opt/cot-explorer && /opt/cot-explorer/venv/bin/python -m src.trading.backtesting.engine >> /opt/cot-explorer/logs/backtest.log 2>&1

# -- Log rotation (daily at midnight) --
0  0  * * *    find /opt/cot-explorer/logs -name "*.log" -size +10M -exec truncate -s 0 {} \;
