{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["name", "description", "domain", "complexity", "model", "tools", "tags", "version"],
  "properties": {
    "name": { "type": "string" },
    "description": { "type": "string", "minLength": 20 },
    "domain": {
      "enum": [
        "development",
        "security",
        "trading",
        "data-ml",
        "devops",
        "seo",
        "product",
        "project-mgmt",
        "writing",
        "orchestration",
        "domain-specific",
        "meta"
      ]
    },
    "complexity": {
      "enum": ["basic", "intermediate", "advanced", "expert"]
    },
    "model": {
      "enum": ["haiku", "sonnet", "opus"]
    },
    "tools": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "related_agents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "version": { "type": "string" }
  }
}
